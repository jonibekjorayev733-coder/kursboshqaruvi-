# ========== DATABASE ==========
DATABASE_URL=postgresql://course_user:password@localhost/course

# ========== STRIPE KEYS ==========
# Get from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_YOUR_STRIPE_PUBLIC_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY

# ========== CLICK KEYS ==========
# Get from https://my.click.uz/dashboard
CLICK_API_KEY=your_click_api_key
CLICK_MERCHANT_ID=your_merchant_id
CLICK_MERCHANT_SERVICE_ID=your_service_id
CLICK_SECRET_KEY=your_click_secret_key

# ========== PAYME KEYS ==========
# Get from https://business.paycom.uz
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_API_KEY=your_payme_api_key

# ========== GOOGLE PAY ==========
GOOGLE_PAY_MERCHANT_ID=your_google_pay_merchant_id
GOOGLE_PAY_MERCHANT_NAME=EduGrow Platform

# ========== APPLICATION ==========
ENVIRONMENT=development
DEBUG=true
